    "aplayer": "^1.10.1",
    "electron": "^27.0.2",
    "electron-builder": "^24.6.4",
    "nuxt": "^3.5.3",
    "nuxt-electron": "^0.6.0",
    "nuxt-lodash": "^2.5.0",
